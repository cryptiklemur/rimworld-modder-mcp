{
  "name": "rimworld-modder-mcp-release",
  "private": true,
  "version": "0.0.0-local",
  "description": "Release automation for RimWorld Modder MCP",
  "scripts": {
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "release:prepare-artifacts": "node scripts/prepare-release-bundle.cjs",
    "release:prepare-bundle": "node scripts/prepare-release-bundle.cjs",
    "release:publish-nuget": "node scripts/publish-nuget-tool.cjs"
  },
  "engines": {
    "node": "^22.14.0 || >=24.10.0"
  },
  "devDependencies": {
    "@semantic-release/exec": "7.1.0",
    "semantic-release": "25.0.3"
  }
}
